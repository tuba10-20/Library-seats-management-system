# Copy this file to .env and fill in your values

# A long random string for session security
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_random_secret_key_here

# Your deployed frontend URL (used for CORS)
# e.g. https://your-library-app.netlify.app
ALLOWED_ORIGINS=https://your-frontend-url.com

# Set to "production" in deployment, "development" for local
FLASK_ENV=production

# Port (Render/Railway set this automatically)
PORT=5000
